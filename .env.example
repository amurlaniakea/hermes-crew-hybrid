# Hermes-Crew Hybrid — Configuración
# Copiar este archivo a .env y ajustar las rutas de tu sistema

# ── Ollama Configuration (REQUERIDO) ─────────────────────────────────────────
# Modelo Ollama a usar. Debe estar instalado localmente.
# Ejemplos:
#   OLLAMA_MODEL=qwen2.5:0.5b                    (rápido, 397MB)
#   OLLAMA_MODEL=batiai/gemma4-e2b:q4             (potente, 3.4GB)
#   OLLAMA_MODEL=llama3:latest                    (meta, 4.7GB)
#   OLLAMA_MODEL=mistral:7b-instruct-v0.3:q4_k_m  (mistral, calidad media)
OLLAMA_MODEL=qwen2.5:0.5b

# URL de Ollama (por defecto: localhost:11434)
OPENAI_API_BASE=http://localhost:11434/v1
OPENAI_API_KEY=ollama

# ── LiteLLM Multi-Model (OPCIONAL) ──────────────────────────────────────────
# Permite usar cualquier proveedor de LLM soportado por LiteLLM.
# Si está vacío, se usa ollama/OLLAMA_MODEL automáticamente.
# Formatos soportados:
#   LITELLM_MODEL=ollama/qwen2.5:0.5b
#   LITELLM_MODEL=openai/gpt-4o
#   LITELLM_MODEL=anthropic/claude-sonnet-4-20250514
#   LITELLM_MODEL=gemini/gemini-1.5-pro
#   LITELLM_MODEL=groq/llama-3.1-70b-versatile
#   LITELLM_MODEL=deepseek/deepseek-coder
#LITELLM_MODEL=

# ── Obsidian Vault Path (OPCIONAL) ───────────────────────────────────────────
# Ruta a tu vault de Obsidian para guardar reportes de seguridad y análisis.
# Ejemplos:
#   Windows (WSL): /mnt/c/Users/TuUsuario/Documents/Obsidian Vault
#   Linux: /home/tuusuario/Documents/Obsidian Vault
#   macOS: /Users/tuusuario/Documents/Obsidian Vault
# Si no se configura, los reportes se guardan en ./ObsidianNotes
OBSIDIAN_VAULT_PATH=

# ── Python Path (OPCIONAL) ───────────────────────────────────────────────────
# Ruta al python3 de tu venv. Si está vacío, se detecta automáticamente.
# Ejemplo: /home/tuusuario/.venvs/hermes/bin/python3
VENV_PYTHON=

# ── Git Safety Log Directory (OPCIONAL) ──────────────────────────────────────
# Directorio para guardar logs de análisis de seguridad.
# Por defecto: /tmp/git_safety_logs
GIT_SAFETY_LOG_DIR=
