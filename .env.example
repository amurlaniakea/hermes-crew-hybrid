# Hermes-Crew Hybrid — Configuración
# Copiar este archivo a .env y ajustar las rutas

# Ollama
OPENAI_API_BASE=http://localhost:11434/v1
OPENAI_API_KEY=ollama

# Obsidian Vault Path (REQUERIDO — cambiar a tu ruta)
# Ejemplo Windows: /mnt/c/Users/TuUsuario/Documents/Obsidian Vault
# Ejemplo Linux: /home/tuusuario/Documents/Obsidian Vault
# Ejemplo macOS: /Users/tuusuario/Documents/Obsidian Vault
OBSIDIAN_VAULT_PATH=/mnt/c/Users/Sil/Documents/Obsidian Vault/Memorias/IA y Computacion

# Python path (opcional — si no se detecta automáticamente)
# VENV_PYTHON=/ruta/a/tu/venv/bin/python3

# Git Safety Log Directory (opcional)
# GIT_SAFETY_LOG_DIR=/tmp/git_safety_logs
